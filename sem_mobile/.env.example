# SEM Mobile - Local Development Environment
# Copy this file to .env and fill in your values

# API Configuration
API_BASE_URL=http://localhost:8070
WS_BASE_URL=ws://localhost:8070/ws
API_TIMEOUT=30000

# App Configuration
APP_ENV=development
APP_NAME=Secure Environment Manager
ENABLE_LOGGING=true
ENABLE_SENTRY=false

# Sentry (only needed if ENABLE_SENTRY=true)
SENTRY_DSN=

# Security
AUTO_LOCK_TIMEOUT=300000
CLIPBOARD_CLEAR_TIMEOUT=30000