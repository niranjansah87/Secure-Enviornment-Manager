# Example .env configuration with email backup settings

# Server Configuration
ADMIN_PASSWORD=your-secure-password-here
DATA_DIR=./data
ENCRYPTION_KEY=your-encryption-key-here

# Email Backup Configuration
# Gmail (Recommended)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-16-char-app-password
BACKUP_EMAIL=backup-recipient@gmail.com

# Optional: Custom backup directory
BACKUP_DIR=./backups

# Other SMTP Examples (uncomment to use)
# Outlook
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587

# Yahoo
# SMTP_SERVER=smtp.mail.yahoo.com
# SMTP_PORT=587

# Custom SMTP
# SMTP_SERVER=your-smtp-server.com
# SMTP_PORT=587

# --- Web UI / Next.js API (optional) ---
# Where the Next.js app is served (Flask redirects legacy HTML routes here)
# FRONTEND_URL=http://localhost:3000
# Comma-separated origins allowed to call /api/v1 from the browser
# CORS_ORIGINS=http://localhost:3000
# Single token with access to all namespaces (list envs, stats). If unset, use per-namespace keys in api_keys.json only.
# MASTER_API_TOKEN=
